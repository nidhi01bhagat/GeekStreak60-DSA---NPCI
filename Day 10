Day 10 : Pythagorean Triplet

class Solution:
    def pythagoreanTriplet(self, arr):
        n = len(arr)
        
        # square all elements
        for i in range(n):
            arr[i] = arr[i] * arr[i]
        
        s = set(arr)
        
        for i in range(n):
            for j in range(i + 1, n):
                if arr[i] + arr[j] in s:
                    return True
        
        return False
