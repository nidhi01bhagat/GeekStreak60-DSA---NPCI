Day  - 20 : Distribute Candies


class Solution:
    def distCandy(self, root):
        self.moves = 0

        def dfs(node):
            if not node:
                return 0

            left = dfs(node.left)
            right = dfs(node.right)

            # count moves
            self.moves += abs(left) + abs(right)

            # return balance to parent
            return node.data + left + right - 1

        dfs(root)
        return self.moves
