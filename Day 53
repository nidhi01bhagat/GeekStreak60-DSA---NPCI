Day 53 : Count Derangements

class Solution:
    def derangeCount(self, n):
        
        # base cases
        
        if n == 1:
            return 0
        if n == 2:
            return 1
        
        # D(n) = (n-1) * (D(n-1) + D(n-2))
        prev2 = 0   # D(1)
        prev1 = 1   # D(2)
        
        for i in range(3, n + 1):
            curr = (i - 1) * (prev1 + prev2)
            prev2 = prev1
            prev1 = curr
        
        return prev1
