Day 35 : class Solution:
    def countWays(self, n, k):
        if n == 1:
            return k
        
        same = 0
        diff = k
        
        for i in range(2, n + 1):
            new_same = diff
            new_diff = (same + diff) * (k - 1)
            
            same = new_same
            diff = new_diff
        
        return same + diff
