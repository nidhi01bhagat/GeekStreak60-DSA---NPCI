Day 39 : Huffman Encoding

import heapq

class Node:
    def __init__(self, freq, char, idx):
        self.freq = freq
        self.char = char
        self.idx = idx
        self.left = None
        self.right = None

    def __lt__(self, other):
        if self.freq == other.freq:
            return self.idx < other.idx
        return self.freq < other.freq


class Solution:
    def huffmanCodes(self, s, f):
        n = len(s)
        
        #  EDGE CASE (IMPORTANT)
        if n == 1:
            return ["0"]
        
        heap = []
        
        for i in range(n):
            heapq.heappush(heap, Node(f[i], s[i], i))
        
        while len(heap) > 1:
            left = heapq.heappop(heap)
            right = heapq.heappop(heap)
            
            newNode = Node(left.freq + right.freq, '$', min(left.idx, right.idx))
            newNode.left = left
            newNode.right = right
            
            heapq.heappush(heap, newNode)
        
        root = heap[0]
        result = []
        
        def preorder(node, code):
            if not node:
                return
            
            if node.char != '$':
                result.append(code)
                return
            
            preorder(node.left, code + "0")
            preorder(node.right, code + "1")
        
        preorder(root, "")
        return result
