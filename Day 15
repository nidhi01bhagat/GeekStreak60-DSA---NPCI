Day 15 : Generate IP Addresses

class Solution:
    def generateIp(self, s):
        res = []
        n = len(s)

        def valid(part):
            if len(part) > 1 and part[0] == '0':
                return False
            if int(part) > 255:
                return False
            return True

        def backtrack(start, parts, path):
            if parts == 4:
                if start == n:
                    res.append(".".join(path))
                return

            for length in range(1, 4):
                if start + length <= n:
                    part = s[start:start+length]
                    if valid(part):
                        backtrack(start+length, parts+1, path+[part])

        backtrack(0, 0, [])
        return res
