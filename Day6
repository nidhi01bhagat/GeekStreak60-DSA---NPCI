Day 6 : Max Xor Subarray of size K

class Solution:
    def maxSubarrayXOR(self, arr, k):
        n = len(arr)
        
        # XOR of first window
        curr_xor = 0
        for i in range(k):
            curr_xor ^= arr[i]
        
        max_xor = curr_xor
        
        # Sliding window
        for i in range(k, n):
            curr_xor ^= arr[i-k]   # remove element leaving window
            curr_xor ^= arr[i]     # add new element
            
            max_xor = max(max_xor, curr_xor)
        
        return max_xor
